# .env.example
# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES
# These represent the current external context and internal capacity you are 
# operating under. You can't always control these, but your SOUL.md system 
# reads them to know how to adjust its output and boundary enforcement.
#
# INSTRUCTIONS: Rename this file to `.env` and update the values to match 
# your current season. 
# -----------------------------------------------------------------------------

# --- EXTERNAL CONTEXT ---
# What is the current state of the industry or your organization?
# (e.g., ai_wave, massive_layoffs, hyper_growth, quiet_period)
INDUSTRY_MODE=ai_wave
COMPANY_CLIMATE=chaotic

# --- INTERNAL CAPACITY ---
# What is your current bandwidth? (Scale of 1-100 or specific descriptors)
CURRENT_BANDWIDTH_PERCENT=70
SOCIAL_BATTERY=low

# --- SEASON OF LIFE ---
# What season are you currently in personally or professionally?
# (e.g., building, resting, learning, surviving, transitioning)
CURRENT_SEASON=learning_and_adapting

# --- SECRETS (Your Deep "Why") ---
# The private drivers that keep you going. These shouldn't be exposed in 
# your public README.md.
PRIVATE_DRIVER="Provide stability for my family while doing work that matters"
